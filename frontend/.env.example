# V1 API endpoint (full URL to the generate-architecture Lambda)
VITE_API_URL=https://xxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod/generate-architecture

# V2 API base URL (base path for all V2 endpoints, e.g. /generate-v2)
VITE_API_BASE_URL=https://xxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# AWS Region for SDK/Cognito configuration
VITE_AWS_REGION=us-east-1

# Cognito Identity Pool ID (used for unauthenticated access to AWS services)
VITE_AWS_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
